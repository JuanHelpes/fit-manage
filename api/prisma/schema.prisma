// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum TipoAlerta {
  AUTOMATICO
  MANUAL
}

model Aluno {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  nome      String
  email    String   @unique
  senha_hash String
  idade     Int?
  login_google Boolean  @default(false)
  fichas    Ficha[]
  evolucoes EvolucaoFisica[]
  alertas   Alerta[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Instrutor {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  nome      String
  email     String   @unique
  senha_hash String
  cref String?   @unique
  especialidade String?
  telefone String?
  horario_atendimento String?
  fichas    Ficha[]
  login_google Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Alerta {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  aluno       Aluno      @relation(fields: [alunoId], references: [id])
  alunoId     String     @db.ObjectId
  ficha       Ficha?     @relation(fields: [fichaId], references: [id])
  fichaId     String?    @db.ObjectId
  tipo        TipoAlerta @default(MANUAL)
  mensagem    String
  lido        Boolean    @default(false)
  data_alerta DateTime   @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model EvolucaoFisica {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  aluno   Aluno   @relation(fields: [alunoId], references: [id])
  alunoId   String   @db.ObjectId
  dataRegistro DateTime @default(now())
  peso      Float
  altura    Float
  medidas   Json
  percentual_gordura Float
  imc       Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ficha {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  aluno   Aluno   @relation(fields: [alunoId], references: [id])
  alunoId   String   @db.ObjectId
  instrutor Instrutor @relation(fields: [instrutorId], references: [id])
  instrutorId String   @db.ObjectId
  objetivo  String
  ativa    Boolean  @default(true)
  data_inicio DateTime @default(now())
  data_fim  DateTime
  treinos Json
  alertas   Alerta[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

}